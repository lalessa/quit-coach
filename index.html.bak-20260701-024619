let curTool=null;
function submitTool(){const t=TOOLS[curTool];if(!t)return;const r=t.read();if(!r)return;if(r.event)saveToolEvent(r.event);renderPatternBoard();toCoach(r.msg);}
function openTool(key){const t=TOOLS[key];if(!t)return;curTool=key;const area=$("#toolArea");if(!area)return;area.innerHTML=t.html();const sb=$("#toolSubmit");if(sb)sb.onclick=submitTool;
  if(key==="gate"){const no=$("#g_no");if(no)no.onclick=()=>{saveToolEvent({mode:"gate",outcome:"did_not_use"});renderPatternBoard();alert("Saved — a time you wanted to and didn't.");};
    const pr=$("#g_pres");if(pr)pr.onclick=()=>{saveToolEvent({mode:"gate",outcome:"conscious_use"});renderPatternBoard();alert("Saved — conscious pre-quit use.");};
    const au=$("#g_auto");if(au)au.onclick=()=>openTool("autopilot");}
  area.scrollIntoView({behavior:"smooth",block:"nearest"});}
function renderTools(){const r=$("#stateRouter");if(!r)return;r.innerHTML="";ROUTER.forEach(([k,ic,label])=>{const b=document.createElement("button");b.className="toolrow";b.innerHTML='<span class="ic">'+ic+'</span><span><span class="tl">'+esc(label)+'</span></span>';b.onclick=()=>openTool(k);r.appendChild(b);});const a=$("#toolArea");if(a)a.innerHTML="";}
let _patRows=[];
function renderPatternBoard(){
  const el=$("#patternBoard");if(!el)return;
  const ev=get("qc2_tools_events",[]),fb=get("qc2_coach_feedback",[]),guard=get("qc2_guard_hits",0);
  const rows=[],topOf=(arr,key)=>{const c={};arr.forEach(e=>{const v=e[key];if(v)c[v]=(c[v]||0)+1;});return Object.entries(c).sort((a,b)=>b[1]-a[1]);};
  const auto=ev.filter(e=>e.mode==="autopilot");
  let t=topOf(auto,"activity");if(t.length)rows.push(["Autopilot happens while",t.slice(0,3).map(x=>x[0]+" ×"+x[1]).join(" · ")]);
  t=topOf(ev,"device");if(t.length)rows.push(["Device usually",t.slice(0,3).map(x=>x[0]+" ×"+x[1]).join(" · ")]);
  let rel=ev.filter(e=>e.relief_from).map(e=>e.relief_from);if(rel.length)rows.push(["'Relief from' answers",[...new Set(rel)].slice(-3).join(", ")]);
  let mp=ev.filter(e=>e.mode==="morning"&&e.promise).map(e=>e.promise);if(mp.length)rows.push(["Morning promise",[...new Set(mp)].slice(-3).join(", ")]);
  let bm=ev.filter(e=>e.mode==="breach"&&e.breach_mode).map(e=>e.breach_mode);if(bm.length)rows.push(["Recent breach modes",bm.slice(-4).join(", ")]);
  if(auto.length)rows.push(["Autopilot episodes logged",String(auto.length)]);
  const gate=ev.filter(e=>e.mode==="gate");
  const didnt=gate.filter(e=>e.outcome==="did_not_use").length;if(didnt)rows.push(["Times you wanted to and didn't",String(didnt)]);
  const conscious=gate.filter(e=>e.outcome==="conscious_use").length;if(conscious)rows.push(["Conscious pre-quit uses",String(conscious)]);
  if(ev.length)rows.push(["Times you came to the lab first",String(ev.length)]);
  if(fb.length){const c={};fb.forEach(f=>c[f.reason]=(c[f.reason]||0)+1);rows.push(["Coach-reply complaints",Object.entries(c).sort((a,b)=>b[1]-a[1]).map(x=>x[0]+" ×"+x[1]).join(" · ")]);}
  if(guard)rows.push(["Old-coach replies the guard caught",String(guard)]);
  _patRows=rows;
  if(!rows.length){el.innerHTML='<div class="empty">No patterns yet. Use a tool above and they\'ll show up here.</div>';return;}
  el.innerHTML=rows.map((r,i)=>'<div class="card" style="padding:11px 13px;margin:6px 0"><div class="body" style="font-size:13px"><b>'+esc(r[0])+':</b> '+esc(r[1])+' <button class="ghost" data-i="'+i+'" style="float:right;padding:3px 9px;font-size:12px">Ask coach</button></div></div>').join("");
  el.querySelectorAll("[data-i]").forEach(b=>b.onclick=()=>{const r=_patRows[+b.dataset.i];showView("coach");send("I'm noticing this pattern: "+r[0]+" — "+r[1]+". Help me understand what it means and what to change.");});
}
const FAIL_REASONS=["Generic coping","Wrong mode","Sounded like AI","Too much beauty/body","Too much science","Used old slogan","Used banned language","Didn't make me think","Treated autopilot like craving","Too long","Too soft","Too motivational","Too clinical","Too abstract","Gendered language"];
function renderFailureReporter(){
  const el=$("#failureReporter");if(!el)return;
  el.innerHTML='<p class="sub" style="margin-top:0">Tap what was off about the coach\'s last reply. It\'s saved so the coach can do better.</p><div class="chips" id="failChips"></div><div id="failCount" class="hint" style="margin-top:8px"></div>';
  const ch=$("#failChips");FAIL_REASONS.forEach(r=>{const b=document.createElement("button");b.className="chip";b.textContent=r;b.onclick=()=>logFailure(r);ch.appendChild(b);});
  const fb=get("qc2_coach_feedback",[]);$("#failCount").textContent=fb.length?fb.length+" flag(s) saved.":"";
}
function logFailure(reason){
  const note=prompt("What felt wrong / what would have landed better? (optional)")||"";
  const fb=get("qc2_coach_feedback",[]);fb.push({t:Date.now(),reason,note});set("qc2_coach_feedback",fb);
  const bb=getBrain();brainAdd(bb,"whatFailed","Coach reply flagged: "+reason+(note?" — "+note:""),"feedback");setBrain(bb);
  renderFailureReporter();
  if(confirm("Saved. Ask the coach to redo its last reply now?")){showView("coach");send("That last reply failed because: "+reason+(note?" — "+note:"")+". Rewrite it using the V1.1 Reasoning Engine — reason with me instead of concluding, no coping drills, no slogans.");}
}
function toolSummary(){
  const ev=get("qc2_tools_events",[]);if(!ev.length){const fb0=get("qc2_coach_feedback",[]);if(!fb0.length)return "";}
  const parts=[],top=(arr,key)=>{const c={};arr.forEach(e=>{const v=e[key];if(v)c[v]=(c[v]||0)+1;});const t=Object.entries(c).sort((a,b)=>b[1]-a[1])[0];return t?t[0]:"";};
  const auto=ev.filter(e=>e.mode==="autopilot");
  const ta=top(auto,"activity");if(ta)parts.push("autopilot use usually happens while "+ta);
  const td=top(ev,"device");if(td)parts.push("device usually "+td);
  const rel=[...new Set(ev.filter(e=>e.relief_from).map(e=>e.relief_from))];if(rel.length)parts.push("'relief from' answers: "+rel.slice(-3).join(", "));
  if(auto.length)parts.push(auto.length+" autopilot episode(s) logged");
  const fb=get("qc2_coach_feedback",[]);if(fb.length)parts.push("recent coach-reply complaints: "+[...new Set(fb.map(f=>f.reason))].slice(-4).join(", "));
  if(!parts.length)return "";
  return "\nTOOL-LAB PATTERNS (summarized — use as quiet context, do not recite): "+parts.join("; ")+".";
}

/* ===================== COACH FEEDBACK (one-shot, applies to next reply) ===================== */
const FB_TAGS=["Generic coping","Wrong mode","Sounded like AI","Too much beauty/body","Too much science","Used old slogan","Used banned language","Didn't make me think","Treated autopilot like craving","Too long","Too soft","Too motivational","Too clinical","Too abstract","Gendered language"];
const TAG_FIX={
"Generic coping":"Do not give coping mechanics — no breathing, timer, hand-flat, walking, water, gum, distraction, or 'cravings pass'. Reason with the user (V1.1 Reasoning Engine).",
"Wrong mode":"Identify the correct state before responding. If unsure, ask one short question to tell apart live craving, relief, autopilot, morning, overwhelm, just-one, breach, or alcohol/social.",
"Sounded like AI":"Use normal human speech. Avoid polished, clever, abstract, or framework-like lines. Sound like a strong human mentor.",
"Too much beauty/body":"Do not use beauty, aging, body-composition, skin, fitness, or appearance framing in the next reply unless the user brings it up.",
"Too much science":"Do not lecture or use mechanism-heavy language. Use plain reasoning.",
"Used old slogan":"Avoid dead slogans: 'it gives you nothing', 'you want the fantasy not the reality', 'that's the loop', 'door closed', 'protected win'.",
"Used banned language":"Check the banned patterns before responding. Avoid old-coach and generic-coping language entirely.",
"Didn't make me think":"Do not just conclude. Ask a question that makes the user examine the belief. Use live reasoning.",
"Treated autopilot like craving":"If the user describes using while distracted or without thinking, do NOT ask what the craving promised. Investigate attention, access, where the device was, and where choice dropped out.",
"Too long":"Keep the next reply very short: 1–3 sentences max.",
"Too soft":"Be warmer but sharper. Don't soothe generically. Make the consequence real.",
"Too motivational":"No motivational-poster language. No 'you're stronger than this', 'you've got this', 'step into your power', or similar.",
"Too clinical":"Don't sound medical or academic. Use normal language.",
"Too abstract":"Use concrete language: tobacco, body, lungs, chest, energy, the device, what happens after. Avoid framework words.",
"Gendered language":"Speak directly as 'you'. Do not use she/her/he/him/guy/girl/man/woman or any gendered labels.",
"Other":"Treat the user's free-text feedback below as the highest-priority correction for the next reply, as long as it doesn't conflict with safety or V1.1."};
let _fbState="";
function getActiveFeedback(){return get(LS.afb,null);}
function setActiveFeedback(fb){fb.pending=true;set(LS.afb,fb);}
function clearActiveFeedback(){localStorage.removeItem(LS.afb);}
function lastAssistantExcerpt(){for(let i=history.length-1;i>=0;i--){if(history[i].role==="assistant")return (history[i].content||"").slice(0,160);}return "";}
function toggleFeedback(tag){
  let fb=getActiveFeedback()||{version:"1.1",tags:[],other:"",createdAt:new Date().toISOString(),pending:true};
  const i=fb.tags.indexOf(tag);if(i>=0)fb.tags.splice(i,1);else fb.tags.push(tag);
  fb.lastAssistantExcerpt=lastAssistantExcerpt();_fbState="";
  if(!fb.tags.length&&!(fb.other&&fb.other.trim()))clearActiveFeedback();else setActiveFeedback(fb);
  renderFeedback();
}
function applyFeedback(){
  const fb=getActiveFeedback();
  if(!fb||(!fb.tags.length&&!(fb.other&&fb.other.trim()))){const st=$("#fbStatus");if(st)st.textContent="Choose a tag or write feedback first.";return;}
  setActiveFeedback(fb);_fbState="saved";renderFeedbackStatus();
  const inp=$("#input");if(inp)inp.focus();
}
function renderFeedback(){
  const wrap=$("#fbChips");if(!wrap)return;
  const fb=getActiveFeedback()||{tags:[],other:""};
  wrap.innerHTML="";
  FB_TAGS.concat(["Other"]).forEach(t=>{const b=document.createElement("button");b.className="chip"+(fb.tags.includes(t)?" on":"");b.textContent=t;b.onclick=()=>toggleFeedback(t);wrap.appendChild(b);});
  const other=$("#fbOther");
  if(other){if(fb.tags.includes("Other")){other.style.display="block";if(document.activeElement!==other)other.value=fb.other||"";}else other.style.display="none";}
  renderFeedbackStatus();
}
function renderFeedbackStatus(){
  const fb=getActiveFeedback();const has=fb&&(fb.tags.length||(fb.other&&fb.other.trim()));
  let txt="";
  if(has)txt=_fbState==="saved"?"Saved. It will adjust the next coach reply.":"Feedback will apply to the next coach reply.";
  else txt=_fbState==="applied"?"Feedback applied.":(_fbState==="cleared"?"Feedback cleared.":"");
  const st=$("#fbStatus");if(st)st.textContent=txt;
  const cl=$("#fbClear");if(cl)cl.style.display=has?"inline-block":"none";
  const ap=$("#fbApply");if(ap)ap.style.opacity=has?"1":".55";
}
function buildActiveFeedbackBlock(fb){
  const tags=fb.tags.filter(t=>t!=="Other");
  let s="\n\n=== ACTIVE USER FEEDBACK ABOUT YOUR LAST REPLY (apply immediately; do NOT thank the user or name these tags — just adjust) ===\nThe user marked your previous reply as off for these reasons:\n"+tags.map(t=>"- "+t).join("\n");
  const fixes=tags.map(t=>TAG_FIX[t]).filter(Boolean);
  if(fb.tags.includes("Other")&&fb.other&&fb.other.trim()){s+="\n\nUser elaboration:\n"+fb.other.trim();fixes.push(TAG_FIX["Other"]);}
  if(fixes.length)s+="\n\nApply this feedback in your next reply:\n"+fixes.map(f=>"- "+f).join("\n");
  s+="\nDo not apologize at length. Correct your behavior by following V1.1 more closely.";
  return s;
}
function archiveActiveFeedback(userText,reply){
  const fb=getActiveFeedback();if(!fb||!fb.pending)return;
  if(!fb.tags.length&&!(fb.other&&fb.other.trim())){clearActiveFeedback();return;}
  const hist=get(LS.fbh,[]);
  hist.push({version:"1.1",tags:fb.tags,other:fb.other||"",lastAssistantExcerpt:fb.lastAssistantExcerpt||"",createdAt:fb.createdAt,appliedAt:new Date().toISOString(),nextUserMessageExcerpt:(userText||"").slice(0,160),assistantExcerpt:(reply||"").slice(0,160),status:"applied"});
  while(hist.length>200)hist.shift();set(LS.fbh,hist);
  clearActiveFeedback();_fbState="applied";
}
function feedbackPatternSummary(){
  const hist=get(LS.fbh,[]);if(hist.length<3)return "";
  const c={};hist.forEach(h=>(h.tags||[]).forEach(t=>{if(t!=="Other")c[t]=(c[t]||0)+1;}));
  const rep=Object.entries(c).filter(e=>e[1]>=3).sort((a,b)=>b[1]-a[1]).slice(0,4).map(e=>e[0]);
  if(!rep.length)return "";
  return "\n\nREPEATED COACH FEEDBACK (historical pattern; current active feedback overrides this): the user often flags — "+rep.join(", ")+". Lean against these by default.";
}

/* ===================== PROACTIVE OPENER (agentic — coach starts the conversation, once/day) ===================== */
function proactiveFocus(){
  const h=new Date().getHours();
  const b=getBrain();
  const acquired=b.cards.filter(c=>c.source!=="seed");
  const autoSig=acquired.some(c=>/autopilot|without (really )?thinking|while (working|absorbed|thinking)/i.test(c.text))||(b.inbox||[]).some(c=>/autopilot|without (really )?thinking/i.test(c.text));
  const cr=get(LS.cravings,[]);const cc={};cr.forEach(c=>cc[c.trig]=(cc[c.trig]||0)+1);
  const topTrig=Object.entries(cc).sort((a,b2)=>b2[1]-a[1])[0];
  const d=daysSince(quitDate);
  const milestone=[1,3,7,14,21,30,60,90,180,365];
  if(h>=4&&h<11)return{key:"morning",hint:"It is the morning window — the most worn-in part of the dependence; the first pull is the body missing nicotine, not real energy."};
  if(autoSig)return{key:"autopilot",hint:"A real pattern to surface gently: tobacco has been slipping in while the user is absorbed in something — not always a craving. Open about where that keeps happening."};
  if(d!=null&&d>=0&&milestone.includes(d+1))return{key:"milestone",hint:"Today is about "+(d+1)+" days free — acknowledge it briefly and ask how they feel, no slogans."};
  if(topTrig&&topTrig[1]>=2)return{key:"trigger",hint:"Their most-logged trigger is '"+topTrig[0]+"'. Open lightly about today."};
  if(h>=18)return{key:"evening",hint:"It is evening — the restless, empty kind of pull can show up in the gaps. Light check-in."};
  return{key:"checkin",hint:"Nothing specific flagged — a short, warm, real check-in."};
}
function localOpener(f){
  switch(f.key){
    case"morning":return "Morning's the worn-in one — that first pull isn't really energy, it's your body missing what it had yesterday. How's it sitting right now?";
    case"autopilot":return "Something I've been noticing: tobacco's been slipping in while you're caught up in something, not really as a craving. Want to look at where that keeps happening?";
    case"milestone":{const d=daysSince(quitDate);return "That's about "+((d||0)+1)+" days now — and not from white-knuckling it. How are you feeling about it today?";}
    case"trigger":return "How's today going so far — anything pulling at you, or are we good right now?";
    case"evening":return "Evenings can get restless — the empty kind of pull. Anything tugging at you, or all good?";
    default:return "Here when you need me. What's going on right now?";
  }
}
async function maybeProactiveOpen(){
  if(busy||!apiKey)return;
  const today=new Date().toISOString().slice(0,10);
  if(get(LS.lastpro,"")===today)return;
  set(LS.lastpro,today);
  const f=proactiveFocus();
  const instr="[SESSION START — you are OPENING the conversation proactively; the user just opened the app, they haven't said anything] "+f.hint+" Say ONE short, natural opening line (1–2 sentences) in your normal voice that starts us reasoning. Pick the single most relevant thing. Do not greet generically, do not list, do not say 'how can I help'. Output only the opening line.";
  busy=true;const sb=$("#send");if(sb)sb.disabled=true;
  const tp=document.createElement("div");tp.className="typing";tp.textContent="Coach is thinking…";$("#chat").appendChild(tp);scrollChat();
  let reply="";
  try{const raw=await callClaude(instr);reply=parseReply(raw).reply;if(!reply||reply==="(no reply)"||BANNED_OUT.test(reply))reply=localOpener(f);}
  catch(e){reply=localOpener(f);}
  tp.remove();
  bubble("coach",reply);history.push({role:"assistant",content:reply});set(LS.hist,history);
  busy=false;if(sb)sb.disabled=false;scrollChat();
}

/* ===================== NAV ===================== */
function renderHeader(){
  const h=new Date().getHours();
  const greet=h<12?"Good morning":(h<18?"Good afternoon":"Good evening");
  const g=$("#greeting");if(g)g.textContent=greet+" — let's see clearly";
  const d=daysSince(quitDate);
  const n=(d==null)?"–":(d<0?(-d):(d+1));
  if($("#dfN"))$("#dfN").textContent=n;
  if($("#dfL"))$("#dfL").textContent=(d==null)?"set quit day":(d<0?"days to go":"days free");
}
function showView(v){
  document.querySelectorAll("#nav button").forEach(b=>b.classList.toggle("active",b.dataset.view===v));
  document.querySelectorAll("#app .view").forEach(el=>el.classList.toggle("active",el.id===v));
  renderHeader();
  if(v==="coach"){scrollChat();renderFeedback();maybeProactiveOpen();}
  if(v==="you"){
    renderProgress();renderAnchor();renderCravings();renderMe();renderMem();renderOutlets();renderAudio();updateMeta();
    $("#programInput").value=get(LS.program,"");
    $("#programStatus").textContent=get(LS.program,"")?"A program is loaded.":"No program loaded — coach uses your built-in plan.";
  }
}

/* ===================== BOOT ===================== */
function buildPanicBar(){
  const chips=$("#chips");if(!chips)return;chips.innerHTML="";
  [["I want tobacco. Help me test what it's actually supposed to fix.","I want tobacco"],
   ["I want relief. Help me figure out — relief from what.","I want relief"],
   ["I used some without really thinking. Help me see what happened.","Used without thinking"],
   ["It's just one. Help me test whether it's really about one.","It's just one"]]
    .forEach(([msg,label])=>{const b=document.createElement("button");b.className="chip";b.textContent=label;b.onclick=()=>{showView("coach");send(msg);};chips.appendChild(b);});
  [["med","⚠️ Chest pain"],["help","💟 I'm struggling"]].forEach(([k,label])=>{const b=document.createElement("button");b.className="chip";b.textContent=label;b.onclick=()=>openPanic(k);chips.appendChild(b);});
}
function buildQuick(){const q=$("#quick");if(!q)return;q.innerHTML="";QUICKS.forEach(t=>{const b=document.createElement("button");b.textContent=t.length>42?t.slice(0,40)+"…":t;b.title=t;b.onclick=()=>{showView("coach");send(t);};q.appendChild(b);});}
function updateMeta(){$("#meta").innerHTML="Model: "+esc(model)+"<br>Private · in this browser";}

function enterApp(){
  $("#setupMain").style.display="none";
  $("#app").style.display="flex";
  buildPanicBar();buildQuick();updateMeta();renderHeader();renderToday();renderMem();renderAudio();renderOutlets();
  $("#programInput").value=get(LS.program,"");
  $("#programStatus").textContent=get(LS.program,"")?"A program is loaded.":"No program loaded — coach uses your built-in plan.";
  $("#chat").innerHTML="";
  if(history.length===0)sysNote("I'm here. Tell me what's going on — or use the chips below for instant help (they work offline).");
  else history.forEach(m=>bubble(m.role,m.content));
  showView("coach");
}

function start(){
  const k=$("#apiKey").value.trim();if(!k){alert("Paste your Anthropic API key.");return;}
  apiKey=k;model=$("#model").value;userName=$("#userName").value.trim();quitDate=$("#quitDate").value;
  set(LS.key,apiKey);set(LS.model,model);set(LS.name,userName);set(LS.quit,quitDate);
  enterApp();
}

