  return '<div class="mrow"><span class="mtext">'+(c.pinned?'📌 ':'')+esc(c.text)+(c.hidden?' <span class="mmut">· hidden</span>':'')+'</span>'+
    '<button class="mmenu" data-mid="'+c.id+'" aria-label="actions">⋯</button>'+
    '<div class="macts" id="acts_'+c.id+'"><button class="ghost" data-cc="edit" data-id="'+c.id+'">Edit</button>'+
    '<button class="ghost" data-cc="pin" data-id="'+c.id+'">'+(c.pinned?'Unpin':'Pin')+'</button>'+
    '<button class="ghost" data-cc="hide" data-id="'+c.id+'">'+(c.hidden?'Show':'Hide from coach')+'</button>'+
    '<button class="ghost danger" data-cc="del" data-id="'+c.id+'">Delete</button>'+
    '<span class="mmut">'+esc(c.source)+'</span></div></div>';
}
function brainRowRead(c){return '<div class="mrow"><span class="mtext">'+(c.pinned?'📌 ':'')+esc(c.text)+'</span></div>';}
function showModal(title,body){
  $("#popInner").className="panel-pop";$("#popTitle").textContent=title;
  $("#popBody").innerHTML='<div style="white-space:pre-wrap;font-size:12.5px;line-height:1.55">'+esc(body)+'</div>';
  $("#popDays").textContent="";
  ["popBack","popNext","popTalk","popDone"].forEach(id=>{const e=$("#"+id);if(e)e.style.display="none";});
  $("#popClose").style.display="inline-block";$("#overlay").classList.add("open");
}
function renderBrain(){
  const el=$("#memBody");if(!el)return;const b=ensureBrain();
  const live=b.cards.filter(c=>c.section!=="deprecated");
  let html='<h4 class="ylabel">What the coach knows about me</h4>';
  const SUM=[
    ["Core quit rule","No tobacco or nicotine, in any form.",["coreRule"]],
    ["Quit history","Quit ~5 years once via belief-change; later quits 6–12 months; no medication.",["quitHistory"]],
    ["My main patterns","Morning pull, autopilot while absorbed, restlessness, overwhelm, alcohol / social offers.",["autopilot","morning","triggers","modes"]],
    ["My coach style","Reason with me live; sharp truth without shame; plain language.",["coachWants"]],
    ["What the coach must avoid","Generic coping drills, old slogans, therapy-bot tone, motivational clichés, gendered language, and overusing IQOS / heated tobacco.",["coachAvoids"]],
    ["My values","Health, energy, the body — with beauty / fitness as one rotating lever.",["values"]]
  ];
  SUM.forEach(([title,collapsed,keys])=>{
    const its=[].concat.apply([],keys.map(k=>b.cards.filter(c=>c.section===k)));
    html+='<details class="sumcard"><summary><span class="st">'+esc(title)+'</span><span class="sd">'+esc(collapsed)+'</span></summary><div class="sbody">'+(its.length?its.map(brainRowRead).join(""):'<div class="empty">nothing yet</div>')+'</div></details>';
  });
  html+='<details class="sumcard"><summary><span class="st">Current phase</span><span class="sd">'+esc(phaseInfo().label)+'</span></summary><div class="sbody"><div class="mmut">Set or change your quit day in Settings (below) to update this.</div></div></details>';
  const pinned=live.filter(c=>c.pinned);
  html+='<h4 class="ylabel">Pinned memories</h4>'+(pinned.length?pinned.map(brainRow).join(""):'<div class="empty">No pinned memories yet.</div>');
  if(b.inbox.length){html+='<h4 class="ylabel">Memory inbox <span class="mmut">('+b.inbox.length+')</span></h4>';
    html+=b.inbox.map(it=>'<div class="mrow"><span class="mtext">'+esc(it.text)+'</span><span class="ibacts"><button class="ghost" data-ib="approve" data-id="'+it.id+'">Approve</button><button class="ghost" data-ib="edit" data-id="'+it.id+'">Edit</button><button class="ghost danger" data-ib="reject" data-id="'+it.id+'">Reject</button></span></div>').join("");}
  let pool=live.slice();if(_brainFilter!=="all")pool=pool.filter(c=>c.section===_brainFilter);
  pool.sort((a,c)=>(c.pinned?1:0)-(a.pinned?1:0));
  html+='<details class="sumcard" id="allMem"><summary><span class="st">All memory</span><span class="sd">Everything stored locally. The coach only receives a sanitized summary.</span></summary><div class="sbody">';
  html+='<div class="chips" style="margin-bottom:8px">'+[["all","All"]].concat(BRAIN_SECTIONS).map(([k,l])=>'<button class="chip'+(_brainFilter===k?' on':'')+'" data-flt="'+k+'">'+esc(l)+'</button>').join("")+'</div>';
  html+=(pool.length?pool.map(brainRow).join(""):'<div class="empty">none</div>');
  html+='<div style="margin-top:12px" class="inputrow2"><input id="brainNew" placeholder="add something the coach should know"><select id="brainSec" style="max-width:150px">'+BRAIN_SECTIONS.map(s=>'<option value="'+s[0]+'">'+esc(s[1])+'</option>').join("")+'</select></div><div class="btnrow"><button class="ghost" id="brainAddBtn">Add</button></div>';
  html+='</div></details>';
  const banned=live.filter(c=>c.section!=="coachAvoids"&&c.section!=="whatFailed"&&BRAIN_BANNED.test(c.text)).length;
  const hidden=live.filter(c=>c.hidden).length;const dep=b.cards.filter(c=>c.section==="deprecated").length;const active=live.filter(c=>!c.hidden).length;
  html+='<details class="sumcard"><summary><span class="st">Memory health</span><span class="sd">'+active+' active · '+hidden+' hidden · '+dep+' deprecated</span></summary><div class="sbody">';
  html+='<div class="mmut" style="font-size:12.5px">Active '+active+' · Hidden '+hidden+' · Deprecated '+dep+' · Banned-phrase hits '+banned+' · Last cleaned '+(b.migratedAt||"never")+'</div>';
  html+='<div class="btnrow" style="margin-top:10px"><button class="ghost" data-bm="preview">Preview memory sent to coach</button><button class="ghost" data-bm="clean">Clean old coach memory</button><button class="ghost" data-bm="exportmem">Export memory</button><button class="ghost" data-bm="cleardep">Clear deprecated</button><button class="ghost danger" data-bm="resetmem">Reset memory only</button></div>';
  html+='</div></details>';
  el.innerHTML=html;wireBrain();
}
function wireBrain(){
  document.querySelectorAll("#memBody [data-bm]").forEach(x=>x.onclick=()=>brainManage(x.dataset.bm));
  document.querySelectorAll("#memBody [data-ib]").forEach(x=>x.onclick=()=>brainInboxAct(x.dataset.ib,x.dataset.id));
  document.querySelectorAll("#memBody [data-cc]").forEach(x=>x.onclick=()=>brainCard(x.dataset.cc,x.dataset.id));
  document.querySelectorAll("#memBody [data-mid]").forEach(x=>x.onclick=()=>{const a=$("#acts_"+x.dataset.mid);if(a)a.classList.toggle("open");});
  document.querySelectorAll("#memBody [data-flt]").forEach(x=>x.onclick=()=>{_brainFilter=x.dataset.flt;renderBrain();const am=$("#allMem");if(am)am.open=true;});
  const add=$("#brainAddBtn");if(add)add.onclick=()=>{const t=$("#brainNew").value.trim();if(!t)return;const b=getBrain();brainAdd(b,$("#brainSec").value,t,"manual");setBrain(b);renderBrain();const am=$("#allMem");if(am)am.open=true;};
}
function brainCard(act,id){const b=getBrain();const c=b.cards.find(x=>x.id===id);if(!c)return;
  if(act==="del"){if(!confirm("Delete this memory?"))return;b.cards=b.cards.filter(x=>x.id!==id);}
  else if(act==="pin")c.pinned=!c.pinned;else if(act==="hide")c.hidden=!c.hidden;
  else if(act==="edit"){const v=prompt("Edit memory:",c.text);if(v==null)return;c.text=v.trim();}
  setBrain(b);renderBrain();}
function brainInboxAct(act,id){const b=getBrain();const it=b.inbox.find(x=>x.id===id);if(!it)return;
  if(act==="reject")b.inbox=b.inbox.filter(x=>x.id!==id);
  else if(act==="edit"){const v=prompt("Edit before approving:",it.text);if(v==null)return;it.text=v.trim();}
  else if(act==="approve"){brainAdd(b,it.section,it.text,it.source);b.inbox=b.inbox.filter(x=>x.id!==id);}
  setBrain(b);renderBrain();}
function brainManage(act){const b=getBrain();
  if(act==="preview"){const p=(memoryPacket()||"").trim()||"(nothing curated yet)";showModal("Memory sent to coach",p);return;}
  if(act==="clean"){let n=0;b.cards.forEach(c=>{if(c.section!=="coachAvoids"&&c.section!=="whatFailed"&&c.section!=="deprecated"&&BRAIN_BANNED.test(c.text)){c.section="deprecated";c.hidden=true;n++;}});b.migratedAt=new Date().toISOString().slice(0,10);setBrain(b);renderBrain();alert(n+" item(s) moved to deprecated.");}
  else if(act==="resetmem"){if(!confirm("Reset the coach's memory to the clean starting set? Your manual additions and approved items will be lost."))return;const nb=newBrain();seedBrain(nb);nb.migratedAt=new Date().toISOString().slice(0,10);setBrain(nb);renderBrain();}
  else if(act==="exportmem"){const blob=new Blob([JSON.stringify(b,null,2)],{type:"application/json"});const a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download="quit-coach-memory-"+new Date().toISOString().slice(0,10)+".json";a.click();}
  else if(act==="cleardep"){if(!confirm("Permanently delete all deprecated items?"))return;b.cards=b.cards.filter(c=>c.section!=="deprecated");setBrain(b);renderBrain();}}

