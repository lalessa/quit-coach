function migrateBrain(b){let poll=0;const consider=(text,section)=>{text=(text||"").toString().trim();if(!text)return;if(BRAIN_BANNED.test(text)){b.cards.push({id:uid(),section:"deprecated",text,source:"migrated",pinned:false,hidden:true,t:Date.now()});poll++;}else brainAdd(b,section,text,"migrated");};
