  set(LS.key,apiKey);set(LS.model,model);set(LS.quit,quitDate);updateMeta();renderToday();renderProgress();alert("Settings saved.");};
$("#exportBtn").onclick=()=>{
  const inclKey=$("#exportKey")&&$("#exportKey").checked;
  if(inclKey&&!confirm("This backup will contain your Anthropic API key in plain text. Only do this if you understand the risk. Continue?"))return;
  const dump={};Object.values(LS).forEach(k=>{if(k===LS.key&&!inclKey)return;dump[k]=get(k,null);});
