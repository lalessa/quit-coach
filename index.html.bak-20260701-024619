<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Quit Coach</title>
<link rel="manifest" href="manifest.webmanifest">
<meta name="theme-color" content="#FBF6EE">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="Quit Coach">
<link rel="apple-touch-icon" href="icon-192.png">
<link rel="icon" href="icon-192.png">
<script>if('serviceWorker' in navigator){window.addEventListener('load',function(){navigator.serviceWorker.register('sw.js').catch(function(){});});}</script>
<style>
  :root{
    --bg:#FBF6EE; --panel:#FFFFFF; --panel2:#F1E6D6; --line:#E9DDCC;
    --text:#3A332B; --muted:#9A8C79; --accent:#BB6A47; --accent2:#A2583A;
    --coach:#FFFFFF; --user:#ECDCC9; --danger:#B0503C; --ok:#6F8650; --warn:#C0883A;
    --radius:16px;
    --serif:"Iowan Old Style",Georgia,"Times New Roman",serif;
  }
  *{box-sizing:border-box}
  html,body{height:100%;margin:0}
  body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    background:var(--bg);color:var(--text);display:flex;flex-direction:column;height:100vh}
  header{display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid var(--line);
    background:var(--panel);flex:0 0 auto}
  header .logo{font-size:18px;font-weight:700}
  header .dot{color:var(--accent)}
  header .meta{font-size:11px;color:var(--muted);margin-left:auto;text-align:right;line-height:1.4}

  nav{display:flex;justify-content:space-around;padding:9px 6px;background:var(--panel);border-top:1px solid var(--line);flex:0 0 auto}
  nav button{background:transparent;border:none;color:var(--muted);padding:5px 20px;font-size:13px;cursor:pointer;font-family:inherit;border-radius:10px}
  nav button:hover{color:var(--text)}
  nav button.active{color:var(--accent);font-weight:500}

  /* PANIC bar always visible */
  .panicbar{display:flex;gap:6px;padding:8px 10px;background:#14171e;border-bottom:1px solid var(--line);
    overflow-x:auto;flex:0 0 auto}
  .panicbar button{flex:0 0 auto;background:#3a1f28;border:1px solid #6e2a3a;color:#ffd9df;
    border-radius:20px;padding:8px 13px;font-size:12.5px;cursor:pointer;white-space:nowrap;font-weight:600}
  .panicbar button:hover{background:#4d2733}
  .panicbar button.help{background:#1f2c3a;border-color:#34506e;color:#cfe2ff}

  main{flex:1 1 auto;overflow-y:auto;min-height:0}
  .view{display:none;padding:18px;max-width:860px;margin:0 auto}
  .view.active{display:block}

  h2{margin:0 0 4px;font-size:20px}
  h3{margin:18px 0 8px;font-size:15px;color:var(--accent)}
  p.sub{color:var(--muted);font-size:13.5px;line-height:1.5;margin:0 0 14px}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:16px;margin:12px 0}
  .card h4{margin:0 0 8px;font-size:14px}
  .card .body{font-size:14px;line-height:1.6;white-space:pre-wrap}
  label{display:block;font-size:12.5px;color:var(--muted);margin:12px 0 5px}
  input,select,textarea{width:100%;padding:10px 11px;background:var(--panel2);border:1px solid var(--line);
    border-radius:9px;color:var(--text);font-size:14px;font-family:inherit}
  textarea{resize:vertical;line-height:1.5}
  .row{display:flex;gap:10px}.row>div{flex:1}
  button.primary{margin-top:16px;padding:11px 18px;background:var(--accent);border:none;border-radius:9px;
    color:#fff;font-size:14px;font-weight:600;cursor:pointer}
  button.primary:hover{background:var(--accent2)}
  button.ghost{background:var(--panel2);border:1px solid var(--line);color:var(--text);border-radius:9px;
    padding:8px 13px;font-size:13px;cursor:pointer}
  button.ghost:hover{border-color:var(--accent)}
  button.ghost.danger{border-color:#5a2a2a;color:#ff8a8a}
  .hint{font-size:11.5px;color:var(--muted);margin-top:10px;line-height:1.5}
  a{color:var(--accent)}
  code{background:var(--panel2);padding:1px 5px;border-radius:5px;font-size:12.5px}

  /* stats */
  .stats{display:flex;gap:10px;flex-wrap:wrap}
  .stat{flex:1;min-width:120px;background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:14px}
  .stat .n{font-size:26px;font-weight:700}
  .stat .l{font-size:11.5px;color:var(--muted);margin-top:2px}
  .phasebadge{display:inline-block;background:var(--panel2);border:1px solid var(--line);border-radius:20px;
    padding:4px 11px;font-size:12px;color:var(--text);margin-top:4px}

  /* chat */
  #coach.view.active{display:flex;flex-direction:column;min-height:100%}
  #chat{display:flex;flex-direction:column;gap:12px;padding:6px 0 0;flex:1 1 auto}
  .msg{max-width:92%;width:fit-content;padding:12px 15px;border-radius:15px;line-height:1.55;font-size:14.5px;white-space:pre-wrap}
  .msg.coach{background:var(--coach);border:1px solid var(--line);border-radius:18px 18px 18px 5px;align-self:flex-start;font-family:var(--serif);font-size:15.5px}
  .msg.user{background:var(--user);border-radius:18px 18px 5px 18px;align-self:flex-end}
  .msg.system{align-self:center;background:transparent;color:var(--muted);font-size:12.5px;border:1px dashed var(--line);text-align:center}
  .typing{align-self:flex-start;color:var(--muted);font-size:13px}
  .composer{position:sticky;bottom:0;display:flex;flex-direction:column;gap:9px;padding:10px 0 12px;background:var(--bg)}
  .chips{display:flex;gap:8px;flex-wrap:wrap}
  .chip{background:var(--panel2);color:var(--accent2);border:none;border-radius:20px;padding:8px 13px;font-size:13px;cursor:pointer;font-family:inherit}
  .chip:hover{filter:brightness(.97)}
  .chip.on{background:var(--accent);color:#fff}
  .fbpanel{margin-top:2px;border-top:1px solid var(--line);padding-top:8px}
  .fbpanel>summary{cursor:pointer;font-size:13px;color:var(--accent);list-style:none}
  .fbpanel>summary::-webkit-details-marker{display:none}
  .ylabel{margin:18px 0 8px;font-size:13px;color:var(--accent);font-weight:500}
  .sumcard{background:var(--panel);border:1px solid var(--line);border-radius:12px;margin:7px 0;overflow:hidden}
  .sumcard>summary{cursor:pointer;list-style:none;padding:12px 14px;display:flex;flex-direction:column;gap:3px}
  .sumcard>summary::-webkit-details-marker{display:none}
  .sumcard .st{font-size:14px;color:var(--text);font-weight:500}
  .sumcard .sd{font-size:12.5px;color:var(--muted);line-height:1.45}
  .sumcard .sbody{padding:4px 14px 12px;border-top:1px solid var(--line)}
  .mrow{display:flex;align-items:flex-start;gap:8px;padding:8px 0;border-bottom:1px solid var(--line);flex-wrap:wrap}
  .mrow:last-child{border-bottom:none}
  .mtext{flex:1;font-size:13px;line-height:1.5;color:var(--text);min-width:0}
  .mmut{color:var(--muted);font-size:11px}
  .mmenu{flex:0 0 auto;background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;line-height:1;padding:0 6px}
  .macts{display:none;flex-basis:100%;gap:6px;flex-wrap:wrap;margin-top:4px;align-items:center}
  .macts.open{display:flex}
  .ibacts{flex:0 0 auto;display:flex;gap:6px;flex-wrap:wrap}
  .macts .ghost,.ibacts .ghost{padding:4px 10px;font-size:12px}
  .inputrow{display:flex;gap:8px;align-items:flex-end}
  .composer textarea{min-height:46px;max-height:150px;border-radius:20px;background:var(--panel);padding:12px 15px}
  .iconbtn{flex:0 0 auto;width:44px;height:44px;border-radius:50%;border:1px solid var(--line);background:var(--panel);color:var(--accent);font-size:19px;cursor:pointer;line-height:1}
  .iconbtn.send{background:var(--accent);border:none;color:#fff;font-size:22px}
  .iconbtn:disabled{opacity:.45}
  .inputrow2{display:flex;gap:8px}
  .btnrow{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
  .quick{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:4px}
  .quick button{background:var(--panel2);border:none;color:var(--accent2);border-radius:18px;padding:7px 12px;font-size:12.5px;cursor:pointer;font-family:inherit}
  .quick button:hover{filter:brightness(.97)}
  .toolgrid{display:flex;flex-direction:column;gap:10px;margin:14px 0 4px}
  .toolrow{display:flex;align-items:center;gap:13px;background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:13px 15px;cursor:pointer;text-align:left;font-family:inherit;width:100%}
  .toolrow:hover{border-color:var(--accent)}
  .toolrow .ic{font-size:20px;flex:0 0 auto;width:24px;text-align:center}
  .toolrow .tl{font-size:14.5px;color:var(--text)}
  .toolrow .td{font-size:12px;color:var(--muted);margin-top:1px}
  .apphead{display:flex;align-items:center;justify-content:space-between;padding:16px 18px 12px;background:var(--bg);border-bottom:none;flex:0 0 auto}
  .greet{font-family:var(--serif);font-size:19px;color:var(--text)}
  .brandsub{font-size:12px;color:var(--muted);margin-top:2px}
  .daysfree{text-align:center;background:var(--panel2);border-radius:14px;padding:6px 13px}
  .daysfree .n{display:block;font-size:17px;color:var(--accent2);font-weight:600;line-height:1.2}
  .daysfree .l{font-size:10px;color:var(--muted)}
  .err{color:var(--danger);font-size:13px;margin:8px 0}

  /* panic overlay */
  .overlay{position:fixed;inset:0;background:rgba(58,51,43,.5);display:none;align-items:flex-start;justify-content:center;
    padding:20px;z-index:50;overflow-y:auto}
  .overlay.open{display:flex}
  .panel-pop{background:var(--panel);border:1px solid var(--line);border-radius:18px;max-width:560px;width:100%;padding:22px;margin:auto}
  .panel-pop.help{border-color:var(--line)}
  .panel-pop h3{margin:0 0 10px;color:var(--accent);font-size:18px}
  .panel-pop.help h3{color:var(--accent)}
  .panel-pop .body{font-size:15px;line-height:1.65;white-space:pre-wrap}
  .panel-pop .acts{display:flex;gap:8px;margin-top:16px;flex-wrap:wrap}
  .ndays{font-size:12px;color:var(--ok);margin-top:8px}

  table{width:100%;border-collapse:collapse;font-size:12.5px;margin-top:6px}
  th,td{border:1px solid var(--line);padding:7px 8px;text-align:left;vertical-align:top}
  th{background:var(--panel2);color:var(--muted)}
  .empty{color:var(--muted);font-style:italic;font-size:13px}
  .listening{background:#5a2230 !important;border-color:#7a2e3e !important;color:#ffd9df !important;animation:pulse 1.1s infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
  ul.mem{margin:4px 0;padding-left:18px}.ul.mem li{margin:3px 0}
</style>
</head>
<body>

<!-- SETUP -->
<main id="setupMain">
<div class="view active" id="setupView" style="max-width:540px">
  <h2>Set up your coach</h2>
  <p class="sub">A private, self-directed coaching tool built around your evidence-based plan: protect first, automate next, test last. Everything stays in this browser; your API key is only ever sent to Anthropic. This is a coaching companion, not therapy or a crisis service.</p>
  <label>Anthropic API key</label>
  <input id="apiKey" type="password" placeholder="sk-ant-..." autocomplete="off">
  <div class="row">
    <div><label>Model</label>
      <select id="model">
        <option value="claude-sonnet-4-6">Claude Sonnet 4.6 (balanced)</option>
        <option value="claude-opus-4-8">Claude Opus 4.8 (strongest)</option>
        <option value="claude-haiku-4-5-20251001">Claude Haiku 4.5 (fastest)</option>
      </select></div>
    <div><label>Name (optional)</label><input id="userName" type="text" placeholder="you"></div>
  </div>
  <label>Quit day (the day you stop all nicotine)</label>
  <input id="quitDate" type="date">
  <div class="hint">Carr-style: you can keep using IQOS through the early build, but set a real quit day. Leave blank to decide later. Get a key at <a href="https://console.anthropic.com/settings/keys" target="_blank">console.anthropic.com</a>.</div>
  <button class="primary" id="startBtn">Start</button>
</div>
</main>

<!-- APP -->
<div id="app" style="display:none;flex:1 1 auto;min-height:0;flex-direction:column">
  <header class="apphead">
    <div>
      <div class="greet" id="greeting">Let's see clearly</div>
      <div class="brandsub">Quit Coach</div>
    </div>
    <div class="daysfree"><span class="n" id="dfN">–</span><span class="l" id="dfL">days free</span></div>
  </header>

  <main>
    <!-- COACH (home) -->
    <div class="view active" id="coach">
      <div id="chat"></div>
      <div class="err" id="err" style="display:none"></div>
      <div class="composer">
        <div class="chips" id="chips"></div>
        <div class="inputrow">
          <button id="micBtn" class="iconbtn" title="Speak" aria-label="Speak">🎤</button>
          <textarea id="input" placeholder="Tell the coach, or tap the mic to talk…"></textarea>
          <button id="send" class="iconbtn send" aria-label="Send">↑</button>
        </div>
        <details class="fbpanel" id="fbPanel">
          <summary>Was a coach reply off?</summary>
          <p class="sub" style="margin:6px 0 8px">Tap what was off about the last reply. The next reply will adjust.</p>
          <div class="chips" id="fbChips"></div>
          <textarea id="fbOther" rows="2" placeholder="Tell the coach what felt off, or what would have landed better…" style="display:none;margin-top:8px"></textarea>
          <div style="display:flex;align-items:center;gap:8px;margin-top:8px;flex-wrap:wrap">
            <button class="ghost" id="fbApply" style="padding:5px 12px;font-size:12.5px">Apply to next reply</button>
            <button class="ghost" id="fbClear" style="display:none;padding:5px 10px;font-size:12px">Clear feedback</button>
            <span id="fbStatus" class="hint" style="margin:0"></span>
          </div>
        </details>
      </div>
    </div>

    <!-- YOU -->
    <div class="view" id="you">
      <h2>You</h2>
      <div class="stats" id="stats"></div>

      <h3>What the coach knows about me</h3>
      <p class="sub">Everything the coach uses, in your control. Edit, hide, pin, or delete anything. Only a clean, curated summary is sent to the coach — never raw logs, old chat, or deprecated notes.</p>
      <div id="memBody"></div>

      <h3>Why I'm quitting — my "toward" statement</h3>
      <p class="sub" style="margin-top:0">The healthy, strong, free version you're moving toward. Lead with what you want — not disgust.</p>
      <textarea id="towardInput" rows="4" placeholder="e.g. I want to breathe easy, feel strong and clear, and be free — not owned by a device. That's who I'm becoming."></textarea>
      <div class="btnrow"><button class="ghost" id="saveToward">Save</button><button class="ghost" id="draftToward">Help me write it</button><button class="ghost" id="micToward">🎤 Speak</button></div>
      <div class="btnrow"><button class="primary" id="onboardBtn" style="margin-top:0">Let the coach set me up (chat)</button></div>

      <h3>My specifics</h3>
      <label>My morning routine (first 30–90 min)</label><textarea id="pmMorning" rows="2" placeholder="what you actually do when you wake"></textarea>
      <label>Where my nicotine physically sits / is reachable</label><input id="pmSpots" placeholder="e.g. bedside table, car, balcony">
      <label>Is coffee paired with using? When?</label><input id="pmCoffee" placeholder="yes/no + when">
      <label>My biggest everyday pull (besides morning)</label><input id="pmTrigger" placeholder="e.g. boredom at home in the evening">
      <button class="primary" id="saveProfile">Save specifics</button>

      <h3>Accountability anchor</h3>
      <p class="sub">One trusted person who knows your rule — someone to text instead of reaching.</p>
      <input id="anchorName" placeholder="Anchor's name / how you'll reach them">
      <div class="btnrow"><button class="ghost" id="saveAnchor">Save anchor</button><button class="ghost" id="draftAnchor">Draft a message</button></div>

      <h3>Weekly check-in</h3>
      <p class="sub">Honest signals so you (and the coach) can tell if it's working — and escalate if it isn't.</p>
      <div class="row"><div><label>Sleep this week (0–10)</label><input id="ciSleep" type="number" min="0" max="10"></div>
        <div><label>Morning difficulty (0–10)</label><input id="ciMorning" type="number" min="0" max="10"></div></div>
      <div class="row"><div><label>Strongest urge (0–10)</label><input id="ciUrge" type="number" min="0" max="10"></div>
        <div><label>Any nicotine use this week?</label><select id="ciUse"><option value="no">No</option><option value="yes">Yes</option></select></div></div>
      <label>Hardest moment / notes</label><textarea id="ciNotes" rows="2"></textarea>
      <button class="primary" id="saveCi">Save check-in</button>
      <div class="card" id="escalateCard" style="display:none">
        <h4 style="color:var(--warn)">Worth escalating</h4>
        <div class="body">Your signals suggest the self-directed structure may not be enough right now. The evidence-backed next step is adding a real cessation counselor (one-to-one beats going solo, and fits a reactance profile better than group). You chose to go without one — this is the agreed escalation, not a failure. Quitline directories: <a href="https://www.who.int/teams/health-promotion/tobacco-control/quitting-tobacco" target="_blank">WHO quitting support</a>.</div>
      </div>

      <h3>Craving log</h3>
      <p class="sub">A quick log builds your real cue map — the coach uses your patterns to get sharper.</p>
      <div class="row">
        <div><label>Intensity (0–10)</label><input id="crInt" type="number" min="0" max="10"></div>
        <div><label>Trigger</label><select id="crTrig"><option>morning</option><option>coffee</option><option>boredom/restless</option><option>overwhelm</option><option>around smokers</option><option>night waking</option><option>other</option></select></div>
        <div><label>Outcome</label><select id="crUse"><option value="held">Held — didn't use</option><option value="used">Used</option></select></div>
      </div>
      <label>Note (optional)</label><input id="crNote" placeholder="what was happening">
      <button class="primary" id="logCraving">Log craving</button>
      <div id="crPattern" style="margin-top:12px"></div>
      <div id="crList"></div>
      <h3>Wins — times you didn't use</h3>
      <div id="winsList"></div>
      <h3>Check-in history</h3>
      <div id="ciList"></div>

      <h3>Outlets — your free / alive list</h3>
      <p class="sub">Where you build the real thing smoking was standing in for, so quitting isn't pure loss. You find it by trying. Anchor it to what you named: travel, the sea, openness, being strong and fit.</p>
      <div class="inputrow2"><input id="outletInput" placeholder="e.g. dawn sea swim, long drive with music, a real gym session"><button class="ghost" id="addOutlet" style="flex:0 0 auto">Add</button></div>
      <div class="btnrow"><button class="ghost" id="findOutlets">Help me find outlets</button></div>
      <div id="outletsList" style="margin-top:14px"></div>

      <h3>Guided regulation audio</h3>
      <p class="sub">Guided <b>regulation</b> (Somatic Experiencing / Polyvagal), not stillness meditation. <b>Sarah Baldwin</b> ("You Make Sense") is your practitioner's lineage; <b>Sarah Blondin</b> (Insight Timer) is a different teacher — don't conflate them.</p>
      <table><thead><tr><th>Title / Teacher</th><th>Where</th><th>For</th><th>When</th></tr></thead>
      <tbody id="audioBody"></tbody></table>
      <label>Paste your audio list (Title — Teacher — Where — State — When)</label>
      <textarea id="audioInput" rows="3" placeholder="Orienting to safety — (SE teacher) — Insight Timer — restless/bored — before reaching"></textarea>
      <button class="ghost" id="saveAudio" style="margin-top:10px">Save audio list</button>

      <h3>Load your program</h3>
      <p class="sub">Paste your full day-by-day program and the coach treats it as the source of truth. If empty, it uses your built-in plan.</p>
      <textarea id="programInput" rows="8" placeholder="Paste your day-by-day program here…"></textarea>
      <button class="ghost" id="saveProgram">Save program</button>
      <div class="hint" id="programStatus"></div>

      <h3>Settings</h3>
      <label>Anthropic API key</label><input id="apiKey2" type="password" autocomplete="off">
      <div class="row"><div><label>Model</label><select id="model2">
        <option value="claude-sonnet-4-6">Claude Sonnet 4.6</option>
        <option value="claude-opus-4-8">Claude Opus 4.8</option>
        <option value="claude-haiku-4-5-20251001">Claude Haiku 4.5</option></select></div>
        <div><label>Quit day</label><input id="quitDate2" type="date"></div></div>
      <button class="ghost" id="saveSettings">Save settings</button>
      <div class="hint" id="meta" style="margin-top:10px"></div>
      <h3>Your data</h3>
      <p class="sub">Everything lives in this browser. Export regularly so a cleared browser never wipes your history.</p>
      <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:var(--muted);margin:8px 0"><input type="checkbox" id="exportKey" style="width:auto"> Include API key in export (off by default)</label>
      <div class="btnrow">
        <button class="ghost" id="clearChat">Clear conversation &amp; old memory</button>
        <button class="ghost" id="exportBtn">Export backup</button>
        <button class="ghost" id="importBtn">Import backup</button>
        <button class="ghost danger" id="resetBtn">Reset everything</button>
        <input type="file" id="importFile" accept="application/json" style="display:none">
      </div>
    </div>
  </main>

  <nav id="nav">
    <button data-view="coach" class="active">Coach</button>
    <button data-view="you">You</button>
  </nav>
</div>

<!-- PANIC / HELP OVERLAY -->
<div class="overlay" id="overlay"><div class="panel-pop" id="popInner">
  <h3 id="popTitle"></h3>
  <div class="body" id="popBody"></div>
  <div class="ndays" id="popDays"></div>
  <div class="acts">
    <button class="ghost" id="popBack" style="display:none">← Back</button>
    <button class="ghost" id="popNext" style="display:none">Next →</button>
    <button class="ghost" id="popTalk">Talk to coach about this</button>
    <button class="ghost" id="popDone">I held the line ✓</button>
    <button class="ghost" id="popClose">Close</button>
  </div>
</div></div>

<script>
"use strict";

/* ===================== EVIDENCE-BASED COACH PROMPT (baked-in, calibrated to this user) ===================== */
