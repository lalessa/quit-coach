const tv=id=>{const e=document.getElementById(id);return e?(e.value||"").trim():"";};
function toCoach(msg){showView("coach");send(msg);}
function saveToolEvent(o){o.t=Date.now();o.source="tool";o.date=new Date().toISOString().slice(0,10);o.confidence=o.confidence||"medium";o.editable=true;const a=get("qc2_tools_events",[]);a.push(o);while(a.length>500)a.shift();set("qc2_tools_events",a);
  const txt=toolEventText(o);if(txt)brainInboxPush(toolEventSection(o),txt,"tool");}
const ROUTER=[["craving","🚬","I want tobacco"],["relief","🌫️","I want relief"],["autopilot","🔁","I used without thinking"],["morning","🌅","I woke up wanting tobacco"],["bored","🌀","I'm bored / restless"],["overwhelm","🌊","I'm overwhelmed"],["justone","☝️","I'm thinking 'just one'"],["breach","🚪","I already used"],["gate","🕯️","Not quitting yet, about to use"],["alcohol","🍷","Offered / drinking"]];
