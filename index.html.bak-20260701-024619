$("#importBtn").onclick=()=>$("#importFile").click();
$("#importFile").onchange=e=>{const f=e.target.files[0];if(!f)return;const r=new FileReader();
  r.onload=()=>{try{const d=JSON.parse(r.result);Object.entries(d).forEach(([k,v])=>{
    if(v==null)return;
    if(k===LS.key){const existing=get(LS.key,"");if(!confirm("This backup contains an API key. Import it"+(existing?" and overwrite your current key?":"?")))return;}
    localStorage.setItem(k,JSON.stringify(v));
  });alert("Imported. Reloading.");location.reload();}catch(err){alert("Bad backup file.");}};r.readAsText(f);};
$("#resetBtn").onclick=()=>{if(!confirm("Erase ALL data and history? Export a backup first if unsure."))return;Object.values(LS).forEach(k=>localStorage.removeItem(k));location.reload();};
$("#clearChat").onclick=()=>{
  if(!confirm("Clear this conversation and the coach's old working memory? Your saved 'about me' notes, wins, profile and program are kept."))return;
  history=[];set(LS.hist,history);
  const _about=(memory&&memory.about_me)?memory.about_me:[];
  memory=blankMem();memory.about_me=_about;set(LS.mem,memory);
  $("#chat").innerHTML="";sysNote("Fresh start. Tell me what's going on.");
  renderMem();showView("coach");
};

/* init */
(function(){
  apiKey=get(LS.key,"");model=get(LS.model,"claude-sonnet-4-6");userName=get(LS.name,"");quitDate=get(LS.quit,"");
